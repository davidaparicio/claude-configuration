{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TASKS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": ["Edit", "Bash(git *)", "Bash(gh *)", "mcp__context7", "mcp__exa"],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Bash(git push --force *)",
      "Bash(*prisma reset*)"
    ],
    "ask": ["Bash(*pr merge*)", "Bash(*prisma reset*)"],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun {CLAUDE_PATH}/scripts/command-validator/src/cli.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 0.1 {CLAUDE_PATH}/song/finish.mp3"
          },
          {
            "type": "command",
            "command": "bun {CLAUDE_PATH}/scripts/auto-rename-session/src/index.ts"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 0.1 {CLAUDE_PATH}/song/need-human.mp3"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "STATUSLINE_DEBUG=1 bun run {CLAUDE_PATH}/scripts/statusline/src/index.ts",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-code-plugins": true
  },
  "spinnerTipsEnabled": false,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high"
}
